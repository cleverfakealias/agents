%% Deployment — runtime topology.
%% Show where code actually executes and what state lives where.
%% Mark regions, zones, and any single points of failure.

flowchart TB
  subgraph edge [Edge / CDN]
    EDGE[Cloudflare Edge<br/>~300 PoPs]
  end

  subgraph compute [Compute]
    WORKER[Workers runtime<br/>per-request isolates]
    DURABLE[Durable Object<br/>per-tenant state]
  end

  subgraph state [State — primary region]
    PG[(Postgres<br/>primary + 1 replica)]
    KV[(Workers KV<br/>eventually consistent)]
    R2[(R2 object store)]
  end

  subgraph obs [Observability]
    LOG[Log drain]
    METRIC[Metrics]
  end

  EDGE --> WORKER
  WORKER --> DURABLE
  WORKER --> PG
  WORKER --> KV
  WORKER --> R2
  WORKER -.-> LOG
  WORKER -.-> METRIC
