{
  "$schema": "https://json.schemastore.org/vscode-mcp.json",
  "inputs": [
    {
      "type": "promptString",
      "id": "gh-pat",
      "description": "GitHub Personal Access Token (read-only for review tasks)",
      "password": true
    }
  ],
  "servers": {
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "${input:gh-pat}"
      },
      "sandboxEnabled": true
    }
  }
}
