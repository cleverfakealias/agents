%% Dataflow — representative request lifecycle.
%% Pick the most load-bearing path (auth'd read, primary write, or hot async path).
%% If the system has more than one critical flow, duplicate this file: dataflow-auth.mmd, dataflow-checkout.mmd, etc.

sequenceDiagram
  autonumber
  participant U as User
  participant W as Web (edge)
  participant A as API
  participant C as Cache
  participant D as DB

  U->>W: GET /resource
  W->>A: fetch(resource, authToken)
  A->>C: GET key
  alt cache hit
    C-->>A: value
  else cache miss
    A->>D: SELECT ... WHERE id = ?
    D-->>A: row
    A->>C: SET key value (TTL)
  end
  A-->>W: 200 JSON
  W-->>U: HTML (SSR) or JSON
